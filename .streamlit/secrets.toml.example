# Streamlit secrets テンプレート
# このファイルをコピーして `secrets.toml` を作り、実際のトークンを記入してください。
# `secrets.toml` は .gitignore で除外されています（git に含まれません）。
#
# Apify token 取得手順:
#   1. https://apify.com/sign-up でアカウント作成（無料）
#   2. ログイン後 https://console.apify.com/settings/integrations にアクセス
#   3. "Personal API tokens" の token をコピー

APIFY_TOKEN = "apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
